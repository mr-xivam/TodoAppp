@model TodoApp.Models.TodoItem
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Add Todo</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #f0f4f8; min-height: 100vh; padding: 2rem; }
        .card { max-width: 520px; margin: 3rem auto; background: white; border-radius: 16px; padding: 2rem; box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
        h2 { color: #1a202c; margin-bottom: 1.5rem; }
        label { display: block; font-size: 0.875rem; font-weight: 500; color: #4a5568; margin-bottom: 0.35rem; }
        input, textarea { width: 100%; padding: 0.65rem 0.9rem; border: 1.5px solid #e2e8f0; border-radius: 8px; font-size: 1rem; margin-bottom: 1.25rem; font-family: inherit; }
        input:focus, textarea:focus { outline: none; border-color: #3182ce; }
        textarea { height: 100px; resize: vertical; }
        .btn-submit { width: 100%; background: #3182ce; color: white; border: none; padding: 0.75rem; border-radius: 8px; font-size: 1rem; font-weight: 500; cursor: pointer; }
        .btn-submit:hover { background: #2b6cb0; }
        .back { display: inline-block; color: #718096; text-decoration: none; margin-top: 1rem; font-size: 0.9rem; }
        .field-error { color: #e53e3e; font-size: 0.8rem; margin-top: -1rem; margin-bottom: 0.75rem; }
    </style>
</head>
<body>
<div class="card">
    <h2>Add New Todo</h2>
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <label asp-for="Title">Title *</label>
        <input asp-for="Title" placeholder="What needs to be done?" required />
        <span asp-validation-for="Title" class="field-error"></span>

        <label asp-for="Description">Description (optional)</label>
        <textarea asp-for="Description" placeholder="Add more details..."></textarea>

        <button type="submit" class="btn-submit">Add Todo ✓</button>
    </form>
    <a href="/Todo" class="back">← Back to list</a>
</div>
</body>
</html>
